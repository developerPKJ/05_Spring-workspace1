package com.kh.web.controller;

import java.io.IOException;
import java.io.PrintWriter;

import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;

import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

/*
 * * Controller 에서 요청을 받아서 처리하는 방법
 * 1. 요청 시 전달값들을 뽑기
 * 2. 그 전달값들을 하나의 VO 객체로 가공하기
 * 3. 가공한 VO 객체를 Service 로 넘기면서 요청 후 결과 받기
 * 4. 결과에 따라 응답화면 지정하기
 */

@Controller // 요청을 받아주는 Controller 역할을 하겠다.
public class BasicController {

	/*
	 * * 요청을 처리하기 위해 요청 시 전달된 값을 얻어내는 방법
	 *   (즉, 사용자가 form 태그 내에서 입력한 값들을 얻어내는 방법)
	 * - HttpServletRequest request 라는 매개변수를 메소드에 정의해준다.
	 * - request 매개변수에는 요청 시 사용자가 form 태그 내에 입력했었던 값들이
	 *   parameter 라는 영역 안에 key (name 속성값) + value (value 속성값) 세트로 담겨오게됨!!
	 *   
	 * - request 의 parameter 영역으로부터 전달된 데이터를 뽑는 메소드
	 *   request.getParameter("키값") : String (밸류값)  
	 *   > 무조건 문자열 타입으로 반환되기 때문에 ~~~~~
	 * 
	 * 	 request.getParameterValues("키값") : String[] (밸류값들)
	 *   > 하나의 key 값으로 여러개의 value 값들을 받을 경우 (특히 체크박스) 유용하게 쓰임!!
	 * 
	 * - 이 때, HttpServletRequest 객체는 매개변수로 정의하면 바로 가져다 쓸 수 있다!!
	 */
	
	/*
	 * * 응답페이지를 만들어서 전달하는 방법
	 * 
	 * - 자바 코드를 이용해서 응답페이지 만들기
	 *   (자바 코드 내에 html 코드를 기술해서 사용자에게 전달하는 방법임!!)
	 * - 이 때, HttpServletResponse 객체가 필요하다.
	 * - 마찬가지로 해당 Controller 메소드의 매개변수로 HttpServletResponse 객체를 정의하면
	 *   바로 가져다 쓸 수 있다!!
	 * 
	 * - 사실 자바 코드를 이용해서 응답페이지를 만드는 방법은 너무 길고 복잡하기 때문에
	 *   현재는 잘 안쓰인다!! (Servlet 방법이라고 부른다)
	 */
	
	// GET 방식으로 test1 에 요청했다면 이 메소드를 실행시키겠다. (호출하겠다)
	@RequestMapping(value="test1", method=RequestMethod.GET)
	public void requestGetController(HttpServletRequest request, 
									 HttpServletResponse response) throws IOException {
		
		// System.out.println("잘 호출 되나..?");
		
		// 요청 시 전달값 뽑아보기 (request 매개변수 객체로부터)
		
		// - 이름 : name
		String name = request.getParameter("name"); 
		// "홍길동" / "" (아무것도 입력 안한 경우에는 빈 문자열 이 넘어온다)
		
		// - 성별 : gender
		String gender = request.getParameter("gender");
		// "M" / "F" / null (아무것도 체크 안한 경우에는 빈 문자열이 아닌 null 이 넘어온다)
		
		// - 나이 : age
		// String age = request.getParameter("age");
		// "20" / "35" / ""
		// > 아무리 숫자로 입력하더라도 무조건 문자열로 넘어오기 때문에 숫자타입으로 변환해서 쓰고자 한다면
		//   "파싱" 해줘야 함!! (Wrapper 클래스에서 제공)
		int age = Integer.parseInt(request.getParameter("age"));
		// "20" -> 20 / "35" -> 35 / "" -> NumberFormatException 발생!!
		// > 빈 문자열이 넘어올 경우에는 파싱하는 과정에서 NumberFormatException 발생하니 주의할 것!!
		
		// - 사는 도시 : city
		String city = request.getParameter("city");
		
		// - 키 : height
		// String height = request.getParameter("height");
		// "179" -> 179.0
		double height = Double.parseDouble(request.getParameter("height"));
		// > 마찬가지로 숫자값이 넘어올 경우 문자열 타입으로 뽑을 수 있고,
		//   해당 숫자에 대응되는 자료형으로 변환해서 취급하고 싶다면 파싱은 필수!!
		//   (마찬가지로 이 과정에서 NumberFormatException 을 주의해야함)
		
		// - 좋아하는 음식 (모두 고르시오) : food
		//   checkbox 요소로 구성했기 때문에 하나의 키값으로 여러개의 value 값이 넘어올 가능성이 큼!!
		String[] foods = request.getParameterValues("food");
		// > ["한식", "일식"] / null
		// > 체크박스도 라디오 버튼과 마찬가지로 체크된 항목이 하나도 없다면 null 이 넘어옴!!
		
		System.out.println("이름 : " + name);
		System.out.println("성별 : " + gender);
		System.out.println("나이 : " + age);
		System.out.println("사는 도시 : " + city);
		System.out.println("키 : " + height);
		// System.out.println("좋아하는 음식 : " + foods); // 주소값
		
		// System.out.println("좋아하는 음식 : " + Arrays.toString(foods));
		// System.out.println("좋아하는 음식 : " + String.join(", ", foods));
		// > foods 배열의 내용을 한줄의 문자열로 연이어서 출력 가능
		//   String.join("구분자", 배열명) : String
		//   배열의 있는 모든 값들을 구분자를 통해서 하나의 문자열로 만들어서 반환해주는 메소드
		
		System.out.print("좋아하는 음식 : ");
		
		if(foods == null) { 
			// > 좋아하는 음식이 없는 경우
			
			System.out.println("없음");
			
		} else {
			// > 좋아하는 음식이 하나 이상이라도 있을 경우
			
			System.out.println(String.join(", ", foods));
		}
		
		// --------------------------------
		
		// 위에서 뽑은 값들을 하나의 VO 객체로 가공하기
		
		// 이 가공한 VO 를 Service 단으로 넘기면서 요청 후 결과 받기 (DB 와 상호작용)
		// > 보통의 흐름 : Service <-> Dao <-> DB
		
		// 마지막으로 결과값에 따라 알맞은 응답화면 (응답페이지) 을 지정
		// > DB 까지 다녀왔다라는 가정 하에 사용자가 보게 될 응답페이지를 만들어서 전달해보자!!
		
		// 자바 코드 안에 html 코드를 기술하여 응답화면 만들어보기
		
		// 1. 이제부터 내가 출력할 내용은 문서형태의 html 이고, 문자셋은 utf-8 임을 지정하기
		response.setContentType("text/html; charset=UTF-8");
		
		// 2. 응답하고자 하는 사용자 (나한테 방금 요청했었던 사용자) 와의 "출력스트림" 을 생성
	 	PrintWriter out = response.getWriter();
		
	 	// 3. 생성된 출력스트림을 통해 응답 html 구문을 한줄씩 내보내기
	 	// (PrintWriter 객체의 println, print, printf 메소드 활용)
	 	out.println("<html>");
	 	
	 	out.println("<head>");
	 	
	 	out.println("<style>");
	 	
	 	out.println("h2 { color : red; }");
	 	out.println("#name { color : orange; }");
	 	out.println("#age { color : yellow; }");
	 	out.println("#city { color : green; }");
	 	out.println("#height { color : blue; }");
	 	out.println("#gender { color : navy; }");
	 	out.println("li { color : purple; }");
	 	
	 	out.println("</style>");
	 	
	 	out.println("</head>");
	 	
	 	out.println("<body>");
	 	
	 	out.println("<h2>개인정보 응답 화면</h2>");
	 	
	 	// out.println("<span id='name'>" + name + "</span> 님은 ");
	 	out.printf("<span id='name'>%s</span> 님은 ", name);
	 	out.printf("<span id='age'>%d</span> 살이며, ", age);
	 	out.printf("<span id='city'>%s</span> 에 사는, ", city);
	 	out.printf("<span id='height'>%.1f</span> cm 이고, ", height);
	 	
	 	out.print("성별은 ");
	 	if(gender == null) {
	 		
	 		out.println("선택을 안했습니다. <br><br>");
	 	
	 	} else {
	 		
	 		if(gender.equals("M")) {
	 			
	 			out.println("<span id='gender'>남자</span> 입니다. <br><br>");
	 			
	 		} else {
	 			
	 			out.println("<span id='gender'>여자</span> 입니다. <br><br>");
	 		}
	 	}
	 	
	 	out.print("좋아하는 음식은 ");
	 	if(foods == null) {
	 		
	 		out.println("없습니다.");
	 		
	 	} else {
	 		
	 		out.print("<ul>");
	 		
	 		for(int i = 0; i < foods.length; i++) {
	 			
	 			out.printf("<li>%s</li>", foods[i]);
	 		}
	 		
	 		out.print("</ul>");
	 	}
	 	
	 	out.println("</body>");
	 	
	 	out.println("</html>");
	 	
	 	// > 스트림의 특징 중 선입선출에 의해 출력문 내의 html 코드가 순서대로 클라이언트 측에 도착해서
	 	//   화면으로 그려지는 원리임!!
	 	
	}
	
//	POST 방식으로 test2에 요청했다면 해당 이 메소드가 호출됨
//	method 요청 방식이 어긋나면 405 에러가 발생
	@RequestMapping(value="test2", method=RequestMethod.POST)
	public void requestPostController() {
//		System.out.println("POST 방식으로 요청이 들어왔네요..!");
		
//		요청 시 전달된 값들을 request의 parameter 영역으로부터 뽑기
		Srting name = request.getParameter("name");
		String gender = request.getParameter("gender")
		int age = Integer.parseInt(request.getParameter("age"));
		String city = request.getParameter("city");
		double height = Double.parseDouble(request.getParameter("height"));
		
	}
	
}









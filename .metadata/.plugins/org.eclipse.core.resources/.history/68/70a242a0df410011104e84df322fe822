<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%
	// 스크립틀릿 : html 태그 내에 자바 코드를 작성할 수 있는 구역
	// 4. 2단계에서 request 객체에 담긴 데이터들을, 꺼내서 변수에 기록하기
	// > request.getParameter("키값")
	String name = (String)request.getAttribute("name");
    int age = (int)request.getAttribute("age");
    String city = (String)request.getAttribute("city");
    double height = (double)request.getAttribute("height");
    String gender = (String)request.getAttribute("gender");
    String[] foods = (String[])request.getAttribute("foods");
    
    System.out.println(name);
    System.out.println(age);
    System.out.println(city);
    System.out.println(height);
    System.out.println(gender);
    System.out.println((foods == null) ? "null" : String.join(", ", foods));
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
	<h2>개인정보 응답화면</h2>
	
	<span id="name"><%= name %></span> 님은
	<span id="age"><%= age %></span> 살이며,
	<span id="city"><%= city %></span> 에 사는,
	<span id="height"><%= height %></span> cm 이고,
	
    성별은
    
    <% if (gender == null) { %>
    
    <!-- case1 -->
    선택 안했습니다. <br><br>
    
    <% } else { %>
    	<% if (gender.equals("M")) { %>
	    <!-- case2_1 -->
	    <span id="gender">남자</span> 입니다.
	    <br><br>
	    
	    <!-- case2_2 -->
	    <span id="gender">여자</span> 입니다.
	    <br><br>
    
    좋아하는 음식은
    
    <!-- case1 -->
    없습니다.
    
    <!-- case2 -->
    <ul>
    	<li></li>
    </ul>
</body>
</html>